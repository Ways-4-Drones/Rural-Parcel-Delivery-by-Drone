let vehicleSpeed[2] := 2200;             # Secondary road speed (ft/min)
let vehicleSpeed[3] := 880;              # Private road speed (ft/min)

# Algorithm parameters
let StepSize := 84;                      # Discretization step for launch/retrieval points (feet)

# ============================================
# NETWORK SIZE
# ============================================
let n := 158;                            # Number of road network nodes
let customers := 58;                     # Number of customers

