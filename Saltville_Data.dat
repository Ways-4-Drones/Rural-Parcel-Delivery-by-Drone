let droneSpeed := 5720;                  # Drone airspeed (ft/min)
let droneServiceTime[1] := 0.083;        # Takeoff time (minutes)
let droneServiceTime[2] := 0.5;          # Customer service time (minutes)
let droneServiceTime[3] := 0.083;        # Landing time (minutes)

# Vehicle parameters
